{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnownQrCodeUrls",
  "default": {
    "urls": []
  },
  "type": "object",
  "properties": {
    "urls": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "openMode": {
            "type": "string",
            "enum": ["in-app-browser", "open-url"]
          }
        },
        "required": ["id", "pattern", "openMode"]
      }
    }
  }
}
